{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client", "node"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "moduleDetection": "legacy",
    "noEmit": true,
    "isolatedModules": false,

    /* TypeScript厳密モード - 段階的改善のため一時的に緩和 */
    "strict": false,                    // 段階的に有効化
    "noImplicitAny": true,              // ✅ 重要: any型の暗黙的な使用を検出（型安全性の要）
    "strictNullChecks": true,           // ✅ 有効化: null/undefinedチェックを強化
    "strictFunctionTypes": true,        // 関数型の厳密なチェック
    "strictBindCallApply": true,        // bind/call/applyの厳密なチェック
    "noImplicitThis": false,            // 🔧 一時的にオフ: プロトタイプ拡張の型問題を段階的に修正
    "alwaysStrict": true,               // strictモードでコンパイル
    "noImplicitReturns": false,         // 🔧 一時的にオフ: 関数の戻り値は段階的に修正
    "noFallthroughCasesInSwitch": true, // switchのfallthrough防止
    "useUnknownInCatchVariables": true, // catch句の変数をunknown型に
    "strictPropertyInitialization": false,  // 🔧 一時的にオフ: プロパティ初期化は段階的に修正
    // "exactOptionalPropertyTypes": true,
    // "noImplicitOverride": true,
    
    /* 未使用変数のチェック - 段階的に修正 */
    "noUnusedLocals": false,            // 🔧 一時的にオフ: 未使用変数は後で整理
    "noUnusedParameters": false,        // 🔧 一時的にオフ: 未使用パラメータは後で整理
    
    /* JavaScript完全排除 */
    "allowJs": false,
    "checkJs": false,
    "allowUmdGlobalAccess": true,
    
    /* 厳密なエラーチェック */
    "noUncheckedIndexedAccess": false,  // 一時的に無効化
    // "noPropertyAccessFromIndexSignature": true,  // インデックスシグネチャのプロパティアクセス制限（後で有効化）
    
    /* 型生成は無効化 */
    "declaration": false,
    "declarationMap": false,
    
    /* ソースマップ */
    "sourceMap": false,
    "inlineSourceMap": false
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules", 
    "dist", 
    "src/encoding.min.ts", 
    "public/**/*",
    "src/japanLatLonMap.ts",
    "src/japanmap.ts",
    "src/worldmap.ts"
  ],
  "ts-node": {
    "compilerOptions": {
      "strict": true,
      "noImplicitAny": true
    }
  }
}
