{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client", "node"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "moduleDetection": "legacy",
    "noEmit": true,
    "isolatedModules": false,

    /* TypeScript厳密モード */
    "strict": false,                    // 段階的に有効化
    "noImplicitAny": true,              // any型の暗黙的な使用を検出
    "strictNullChecks": true,           // null/undefinedの厳密なチェック
    "strictFunctionTypes": true,        // 関数型の厳密なチェック
    "strictBindCallApply": true,        // bind/call/applyの厳密なチェック
    "noImplicitThis": true,             // thisの暗黙的なany型を検出
    "alwaysStrict": true,               // strictモードでコンパイル
    "noImplicitReturns": true,          // 関数の全パスでreturnを強制
    "noFallthroughCasesInSwitch": true, // switchのfallthrough防止
    "useUnknownInCatchVariables": true, // catch句の変数をunknown型に
    "strictPropertyInitialization": true,   // クラスプロパティの初期化チェック
    // "exactOptionalPropertyTypes": true,
    // "noImplicitOverride": true,
    
    /* 未使用変数のチェック */
    "noUnusedLocals": true,             // 未使用のローカル変数を検出
    "noUnusedParameters": true,         // 未使用のパラメータを検出（_で始まる場合は除外）
    
    /* JavaScript完全排除 */
    "allowJs": false,
    "checkJs": false,
    "allowUmdGlobalAccess": true,
    
    /* 厳密なエラーチェック */
    "noUncheckedIndexedAccess": false,  // 一時的に無効化
    // "noPropertyAccessFromIndexSignature": true,  // インデックスシグネチャのプロパティアクセス制限（後で有効化）
    
    /* 型生成は無効化 */
    "declaration": false,
    "declarationMap": false,
    
    /* ソースマップ */
    "sourceMap": false,
    "inlineSourceMap": false
  },
  "include": ["src/**/*", "playwright.config.ts", "tests/e2e/**/*"],
  "exclude": ["node_modules", "dist", "src/encoding.min.ts", "public/**/*"],
  "ts-node": {
    "compilerOptions": {
      "strict": true,
      "noImplicitAny": true
    }
  }
}
