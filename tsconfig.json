{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client", "node"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "moduleDetection": "legacy",
    "noEmit": true,
    "isolatedModules": false,

    /* TypeScript厳密モード */
    "strict": false,                    // 段階的に有効化
    "noImplicitAny": false,             // any型の暗黙的な使用を一時的に許可
    "strictNullChecks": false,          // null/undefinedの厳密なチェックを一時的に無効化
    "strictFunctionTypes": true,        // 関数型の厳密なチェック
    "strictBindCallApply": true,        // bind/call/applyの厳密なチェック
    "noImplicitThis": false,            // thisの暗黙的なanyを一時的に許可
    "alwaysStrict": true,               // strictモードでコンパイル
    "noImplicitReturns": false,         // 関数の全パスでreturnを一時的に無効化
    "noFallthroughCasesInSwitch": true, // switchのfallthrough防止
    "useUnknownInCatchVariables": true, // catch句の変数をunknown型に
    "strictPropertyInitialization": false,  // クラスプロパティの初期化チェックを一時的に無効化
    // "exactOptionalPropertyTypes": true,
    // "noImplicitOverride": true,
    
    /* 未使用変数のチェック */
    "noUnusedLocals": false,            // 一時的に無効化
    "noUnusedParameters": false,        // 一時的に無効化
    
    /* JavaScript完全排除 */
    "allowJs": false,
    "checkJs": false,
    "allowUmdGlobalAccess": true,
    
    /* 厳密なエラーチェック */
    "noUncheckedIndexedAccess": false,  // 一時的に無効化
    // "noPropertyAccessFromIndexSignature": true,  // インデックスシグネチャのプロパティアクセス制限（後で有効化）
    
    /* 型生成は無効化 */
    "declaration": false,
    "declarationMap": false,
    
    /* ソースマップ */
    "sourceMap": false,
    "inlineSourceMap": false
  },
  "include": ["src/**/*", "playwright.config.ts", "tests/e2e/**/*"],
  "exclude": ["node_modules", "dist", "src/encoding.min.ts", "public/**/*"],
  "ts-node": {
    "compilerOptions": {
      "strict": true,
      "noImplicitAny": true
    }
  }
}
