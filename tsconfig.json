{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "moduleDetection": "legacy",
    "noEmit": true,
    "isolatedModules": false,

    /* TypeScript厳密モード - 段階的に有効化 */
    "strict": false,                    // 将来的にtrueに設定予定
    "noImplicitAny": true,              // any型の暗黙的な使用を禁止
    "strictNullChecks": true,           // null/undefinedの厳密なチェック
    "strictFunctionTypes": true,        // 関数型の厳密なチェック
    "strictBindCallApply": true,        // bind/call/applyの厳密なチェック
    "noImplicitThis": true,             // thisの暗黙的なanyを禁止
    "alwaysStrict": true,               // strictモードでコンパイル
    "noImplicitReturns": true,          // 関数の全パスでreturnを強制
    "noFallthroughCasesInSwitch": true, // switchのfallthrough防止
    "useUnknownInCatchVariables": true, // catch句の変数をunknown型に
    // "strictPropertyInitialization": true,  // クラスプロパティの初期化チェック（後で有効化）
    // "exactOptionalPropertyTypes": true,
    // "noImplicitOverride": true,
    
    /* 未使用変数のチェック */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    
    /* JavaScript完全排除 */
    "allowJs": false,
    "checkJs": false,
    "allowUmdGlobalAccess": true,
    
    /* 厳密なエラーチェック */
    "noUncheckedIndexedAccess": true,  // 配列・オブジェクトのインデックスアクセスを厳密化
    // "noPropertyAccessFromIndexSignature": true,  // インデックスシグネチャのプロパティアクセス制限（後で有効化）
    
    /* 型生成は無効化 */
    "declaration": false,
    "declarationMap": false,
    
    /* ソースマップ */
    "sourceMap": false,
    "inlineSourceMap": false
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "src/encoding.min.ts", "public/**/*"],
  "ts-node": {
    "compilerOptions": {
      "strict": true,
      "noImplicitAny": true
    }
  }
}
